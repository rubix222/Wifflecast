rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Public collections ────────────────────────────────────────
    // players, teams, games, and tournaments are readable by anyone
    // (including non-signed-in visitors) so the site works without login.
    // Writes always require authentication.

    match /players/{id} {
      allow read:  if true;
      allow write: if request.auth != null;
    }
    match /teams/{id} {
      allow read:  if true;
      allow write: if request.auth != null;
    }
    match /games/{id} {
      allow read:  if true;
      allow write: if request.auth != null;
    }
    match /tournaments/{id} {
      allow read:  if true;
      allow write: if request.auth != null;
    }

    // ── Private: user profiles ────────────────────────────────────
    // Users can only see their own profile; admin reads all profiles.
    match /users/{uid} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
